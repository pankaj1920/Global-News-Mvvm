<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.auth.VerifyPasswordFragment">

  <androidx.constraintlayout.widget.ConstraintLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content">

      <ImageView
          android:id="@+id/otpLogo"
          android:layout_width="match_parent"
          android:layout_height="130dp"
          android:layout_marginTop="40dp"
          android:src="@drawable/otp_img"
          app:layout_constraintEnd_toEndOf="parent"
          app:layout_constraintStart_toStartOf="parent"
          app:layout_constraintTop_toTopOf="parent" />

      <TextView
          android:id="@+id/otpTxt"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginStart="20dp"
          android:layout_marginEnd="20dp"
          android:layout_marginTop="40dp"
          android:layout_marginBottom="30dp"
          android:gravity="center"
          android:padding="10dp"
          android:text="OTP has been sent to your mobile phone. please enter it below"
          android:textSize="20sp"
          app:layout_constraintEnd_toEndOf="parent"
          app:layout_constraintStart_toStartOf="parent"
          app:layout_constraintTop_toBottomOf="@+id/otpLogo" />

      <EditText
          android:id="@+id/loginPassword"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginStart="30dp"
          android:layout_marginTop="50dp"
          android:layout_marginEnd="30dp"
          android:layout_marginBottom="88dp"
          android:hint="Enter Password"
          android:inputType="number"
          app:layout_constraintEnd_toEndOf="parent"
          app:layout_constraintStart_toStartOf="parent"
          app:layout_constraintTop_toBottomOf="@id/otpTxt"
          android:importantForAutofill="no" />


      <Button
          android:id="@+id/LoginVerifyPassword"
          android:layout_width="300dp"
          android:layout_height="wrap_content"
          android:layout_marginBottom="120dp"
          android:text="Verify"
          android:layout_marginTop="100dp"
          android:background="@drawable/button_bg"
          android:textColor="@color/white"
          app:layout_constraintTop_toBottomOf="@id/loginPassword"
          app:layout_constraintEnd_toEndOf="parent"
          app:layout_constraintStart_toStartOf="parent" />

  </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>